# credentials.yml.template
# Copy this file to credentials.yml and fill in your API keys
# Note: credentials.yml is in .gitignore and should NOT be committed

# OpenAI API Configuration
gpt-4o:
  api_key: "sk-your-openai-api-key-here"
  # base_url: "https://api.openai.com/v1"  # Optional, defaults to OpenAI

gpt-4o-mini:
  api_key: "sk-your-openai-api-key-here"
  # base_url: "https://api.openai.com/v1"  # Optional

# Google Gemini API Configuration
gemini-1.5-flash:
  api_key: "your-gemini-api-key-here"

# Azure OpenAI Configuration
# Use format: azure-{deployment-name}
azure-gpt-4o-mini:
  api_key: "your-azure-subscription-key"
  endpoint: "https://data-formulator.openai.azure.com/"
  deployment: "gpt-4o-mini"
  api_version: "2025-01-01-preview"

